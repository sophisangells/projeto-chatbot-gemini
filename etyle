    border-radius: 20px;
}

div[data-testid="stSidebar"] {
    background-color: #ffd6eb;
}
</style>

""", unsafe_allow_html=True)

st.title("🎀 Gyaru Fashion AI ✨")
st.caption("💖 Sua melhor amiga para dicas de moda, beleza e estilo 💖")

st.title("👗 Fashion Style AI")
st.caption("Sua consultora virtual de moda e estilo")

# Chave da API
chave_api = st.sidebar.text_input(
    "Digite sua chave da API Gemini",
    type="password"
)

if not chave_api:
    st.warning("Insira sua chave de API na barra lateral.")
    st.stop()

cliente = genai.Client(api_key=chave_api)

# Histórico
if "historico" not in st.session_state:
    st.session_state.historico = []

# Botão para limpar conversa
if st.sidebar.button("🗑️ Limpar conversa"):
    st.session_state.historico = []
    st.rerun()

# Exibir histórico
for mensagem in st.session_state.historico:
    with st.chat_message(mensagem["role"]):
        st.markdown(mensagem["content"])

# Entrada do usuário
entrada_usuario = st.chat_input(
    "Pergunte sobre moda, tendências ou combinações..."
)

if entrada_usuario:

    st.session_state.historico.append({
        "role": "user",
        "content": entrada_usuario
    })

    with st.chat_message("user"):
        st.markdown(entrada_usuario)

    with st.chat_message("assistant"):
        with st.spinner("Montando seu look... 👗"):
            resposta_ia = gerar_resposta()

        st.markdown(resposta_ia)

    st.session_state.historico.append({
        "role": "assistant",
        "content": resposta_ia
    })
